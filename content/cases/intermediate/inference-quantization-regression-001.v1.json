  "debrief": {
    "summary": "INT4 校准集缺少生产中的法语长上下文，整体平均掩盖了引用质量回退。正确路径是暂停扩容、使用代表性分层 gate 选择 INT8 候选，并以不可变制品和 canary 保留快速回滚。",
    "rootCause": "量化校准与评估分布不代表生产关键分层，发布又过度关注总体分数和延迟。",
    "correctApproach": [
      "暂停 INT4 扩大并保留受影响分层指标。",
      "构建脱敏合成或公开样本覆盖法语长上下文。",
      "以质量、延迟、成本和回滚联合门槛验证 INT8。",
      "用不可变 digest 做独立 canary 并保留 FP16 回滚。"
    ],
    "keyLessons": [
      "平均质量指标会掩盖重要分层回退。",
      "推理优化必须在代表性校准与多目标门槛下评估。",
      "不可变模型与镜像制品是可信回滚基础。"
    ],
    "interviewerPerspective": "观察候选人是否能抵抗单纯延迟收益，定位数据代表性问题，并把模型评估与部署可逆性连接起来。",
    "customerRiskPerspective": "引用遗漏可能影响法律研究判断；透明暂停、分层验证和快速回滚保护客户信任。",
    "remediation": [
      "建立语言、上下文长度和任务类型分层的校准与评估集。",
      "把关键分层质量门槛加入推理发布 gate。",
      "禁止生产使用可变 latest 标签并规定制品保留期。"
    ],
    "verification": [
      "确认 INT8 在法语长上下文 recall 不低于 0.85。",
      "确认 overall recall 与 p95 同时满足发布门槛。",
      "确认 canary 与基线请求可按版本区分。",
      "演练 digest 级 FP16 回滚并确认五分钟内恢复。"
    ],
