{
  "$id": "https://fde-arena.local/schemas/content-manifest.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "activeCaseIds": {
      "items": {
        "maxLength": 160,
        "minLength": 1,
        "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$",
        "type": "string"
      },
      "type": "array"
    },
    "activeCases": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "caseId": {
            "maxLength": 160,
            "minLength": 1,
            "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$",
            "type": "string"
          },
          "version": {
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991,
            "type": "integer"
          }
        },
        "required": [
          "caseId",
          "version"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "activePublishedCaseCount": {
      "maximum": 9007199254740991,
      "minimum": 0,
      "type": "integer"
    },
    "allCaseIds": {
      "items": {
        "maxLength": 160,
        "minLength": 1,
        "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$",
        "type": "string"
      },
      "type": "array"
    },
    "cases": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "caseId": {
            "maxLength": 160,
            "minLength": 1,
            "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$",
            "type": "string"
          },
          "contentHash": {
            "pattern": "^sha256:[a-f0-9]{64}$",
            "type": "string"
          },
          "path": {
            "pattern": "^content\\/cases\\/(?:beginner|intermediate|advanced)\\/[a-z0-9./-]+\\.json$",
            "type": "string"
          },
          "schemaVersion": {
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991,
            "type": "integer"
          },
          "status": {
            "enum": [
              "planned",
              "draft",
              "reviewed",
              "published",
              "deprecated"
            ],
            "type": "string"
          },
          "version": {
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991,
            "type": "integer"
          }
        },
        "required": [
          "caseId",
          "version",
          "schemaVersion",
          "status",
          "path",
          "contentHash"
        ],
        "type": "object"
      },
      "maxItems": 1000,
      "type": "array"
    },
    "caseVersionCount": {
      "maximum": 9007199254740991,
      "minimum": 0,
      "type": "integer"
    },
    "checksum": {
      "pattern": "^sha256:[a-f0-9]{64}$",
      "type": "string"
    },
    "contentVersion": {
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$",
      "type": "string"
    },
    "displayName": {
      "maxLength": 100000,
      "minLength": 1,
      "type": "string"
    },
    "domainCaseCounts": {
      "additionalProperties": {
        "maximum": 9007199254740991,
        "minimum": 0,
        "type": "integer"
      },
      "propertyNames": {
        "maxLength": 160,
        "minLength": 1,
        "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$",
        "type": "string"
      },
      "type": "object"
    },
    "domains": {
      "items": {
        "maxLength": 160,
        "minLength": 1,
        "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$",
        "type": "string"
      },
      "type": "array"
    },
    "packId": {
      "maxLength": 160,
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$",
      "type": "string"
    },
    "releasedAt": {
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
      "type": "string"
    },
    "schemaVersion": {
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991,
      "type": "integer"
    }
  },
  "required": [
    "packId",
    "displayName",
    "contentVersion",
    "schemaVersion",
    "releasedAt",
    "activePublishedCaseCount",
    "caseVersionCount",
    "activeCases",
    "activeCaseIds",
    "allCaseIds",
    "domains",
    "domainCaseCounts",
    "cases",
    "checksum"
  ],
  "title": "FDE Arena Content Manifest",
  "type": "object"
}
