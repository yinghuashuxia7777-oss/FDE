{
  "$id": "https://fde-arena.local/schemas/skill-rubric.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "rubrics": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "criteria": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "criterionId": {
                  "maxLength": 160,
                  "minLength": 1,
                  "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$",
                  "type": "string"
                },
                "critical": {
                  "type": "boolean"
                },
                "description": {
                  "maxLength": 10000,
                  "minLength": 1,
                  "type": "string"
                },
                "evidenceTypes": {
                  "items": {
                    "maxLength": 160,
                    "minLength": 1,
                    "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$",
                    "type": "string"
                  },
                  "maxItems": 100,
                  "minItems": 1,
                  "type": "array"
                },
                "weight": {
                  "exclusiveMinimum": 0,
                  "maximum": 1,
                  "type": "number"
                }
              },
              "required": [
                "criterionId",
                "description",
                "evidenceTypes",
                "weight",
                "critical"
              ],
              "type": "object"
            },
            "maxItems": 100,
            "minItems": 1,
            "type": "array"
          },
          "evidenceTypes": {
            "items": {
              "maxLength": 160,
              "minLength": 1,
              "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$",
              "type": "string"
            },
            "maxItems": 100,
            "minItems": 1,
            "type": "array"
          },
          "id": {
            "maxLength": 160,
            "minLength": 1,
            "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$",
            "type": "string"
          },
          "metadata": {
            "additionalProperties": false,
            "properties": {
              "author": {
                "maxLength": 10000,
                "minLength": 1,
                "type": "string"
              },
              "createdAt": {
                "format": "date-time",
                "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
                "type": "string"
              },
              "reviewedAt": {
                "anyOf": [
                  {
                    "format": "date-time",
                    "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "reviewer": {
                "anyOf": [
                  {
                    "maxLength": 10000,
                    "minLength": 1,
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            },
            "required": [
              "createdAt",
              "reviewedAt",
              "author",
              "reviewer"
            ],
            "type": "object"
          },
          "schemaVersion": {
            "const": 1,
            "type": "number"
          },
          "skillId": {
            "maxLength": 160,
            "minLength": 1,
            "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$",
            "type": "string"
          },
          "status": {
            "enum": [
              "draft",
              "reviewed",
              "published"
            ],
            "type": "string"
          },
          "thresholds": {
            "additionalProperties": false,
            "properties": {
              "competent": {
                "maximum": 100,
                "minimum": 0,
                "type": "number"
              },
              "learning": {
                "maximum": 100,
                "minimum": 0,
                "type": "number"
              },
              "proficient": {
                "maximum": 100,
                "minimum": 0,
                "type": "number"
              }
            },
            "required": [
              "learning",
              "competent",
              "proficient"
            ],
            "type": "object"
          },
          "title": {
            "maxLength": 10000,
            "minLength": 1,
            "type": "string"
          },
          "version": {
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991,
            "type": "integer"
          }
        },
        "required": [
          "schemaVersion",
          "id",
          "skillId",
          "version",
          "status",
          "title",
          "evidenceTypes",
          "criteria",
          "thresholds",
          "metadata"
        ],
        "type": "object"
      },
      "maxItems": 1000,
      "type": "array"
    },
    "rubricSetVersion": {
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "type": "string"
    },
    "schemaVersion": {
      "const": 1,
      "type": "number"
    },
    "skillCatalogVersion": {
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "type": "string"
    },
    "status": {
      "enum": [
        "draft",
        "reviewed",
        "published"
      ],
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "rubricSetVersion",
    "skillCatalogVersion",
    "status",
    "rubrics"
  ],
  "title": "FDE Arena V1 Skill Rubric Catalog",
  "type": "object"
}
