{
  "$id": "https://fde-arena.local/schemas/domain.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "description": {
      "maxLength": 100000,
      "minLength": 1,
      "type": "string"
    },
    "id": {
      "maxLength": 160,
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$",
      "type": "string"
    },
    "label": {
      "maxLength": 100000,
      "minLength": 1,
      "type": "string"
    },
    "schemaVersion": {
      "const": 1,
      "type": "number"
    },
    "status": {
      "enum": [
        "active",
        "deprecated"
      ],
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "label",
    "description",
    "status"
  ],
  "title": "FDE Arena Domain",
  "type": "object"
}
